        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "@vitest/coverage-v8": "^4.0.16",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "9.39.2",
