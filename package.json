        "@mui/material": "^7.0.0",
        "@mui/x-date-pickers": "^8.22.1",
        "@tanstack/react-query": "^5.90.19",
        "@tanstack/react-router": "^1.142.8",
        "@tanstack/router-vite-plugin": "^1.166.27",
        "axios": "^1.13.5",
        "echarts": "^6.0.0",
        "echarts-for-react": "^3.0.5",
        "html2canvas": "^1.4.1",
        "jspdf": "4.2.1",
        "material-react-table": "^3.2.1",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
